NODE_ENV=
FRONTEND_URL=
GATEWAY_PORT=
USERS_HOST=
USERS_PORT=
AUCTIONS_HOST=
AUCTIONS_PORT=
MONGODB_URI=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
JWT_SECRET=
JWT_EXPIRES_IN=

# --- Redis ---
# Cloud mode (Upstash): set REDIS_URL, leave REDIS_HOST/REDIS_PORT empty
# Rollback mode (local container): leave REDIS_URL empty, set REDIS_HOST + REDIS_PORT
REDIS_URL=
REDIS_HOST=
REDIS_PORT=

# --- RabbitMQ ---
# Cloud mode (CloudAMQP): RABBITMQ_URL=amqps://user:pass@host/vhost
# Rollback mode (local container): RABBITMQ_URL=amqp://user:password@rabbitmq:5672
RABBITMQ_URL=
# Only needed for local container rollback mode:
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=